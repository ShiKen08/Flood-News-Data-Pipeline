# =============================================================================
# Flood Pipeline — .gitignore
# =============================================================================
# Large pipeline data — store these in shared cloud storage, NOT git.
# See README.md → "Shared Data Storage" for instructions.
# =============================================================================

# --- Pipeline data directories (can be GBs) ---
cache/
output/
logs/
raw_index_responses/

# --- Trained model weights (too large for git — use scp to transfer) ---
classifier/model/

# --- Large file types ---
*.warc
*.warc.gz
*.parquet


# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Secrets ---
.env
*.key
*.pem

# --- Local tooling ---
.claude/

# --- Project files not for repo ---
*.pdf
